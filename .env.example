# ─── ChromaDB ────────────────────────────────────────────────────────────────
# URL of your running ChromaDB instance
CHROMA_URL=http://localhost:8000

# ─── Embedding Provider ───────────────────────────────────────────────────────
# Options: openai | ollama | local
# - openai  → uses OpenAI Embeddings API (best quality, requires API key)
# - ollama  → uses a local Ollama model (free, runs on your machine)
# - local   → deterministic hash embedding (no dependencies, for testing only)
EMBEDDING_PROVIDER=openai

# ─── Embedding Model (optional — sensible defaults are applied) ───────────────
# openai  → text-embedding-3-small | text-embedding-3-large | text-embedding-ada-002
# ollama  → nomic-embed-text | mxbai-embed-large | all-minilm
EMBEDDING_MODEL=text-embedding-3-small

# ─── OpenAI (required when EMBEDDING_PROVIDER=openai) ────────────────────────
OPENAI_API_KEY=sk-...

# ─── Ollama (required when EMBEDDING_PROVIDER=ollama) ────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
